# App admin (Expo Web) — variáveis de ambiente
#
# O .env canônico vive na RAIZ do monorepo. Rode `npm run sync-env` na
# raiz para copiar o arquivo para este app. Nunca commitar `.env`.
# Veja a lista completa e origens em ../../.env.example

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Spedy: configure SPEDY_API_KEY e SPEDY_BASE_URL (ex.: https://sandbox-api.spedy.com.br/v1)
# apenas nos secrets do projeto Supabase (Edge Functions lookup-spedy-invoice e get-fiscal-document-pdf).
# Não use EXPO_PUBLIC_ para chave Spedy.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Playwright (opcional, apenas para rodar os testes E2E do admin) ---
# Usuário com app_metadata.role = 'admin'. Sem essas variáveis os testes
# autenticados são marcados como skip.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# E2E_REQUIRE_DB_ROWS=1   # opcional: exige dados nas tabelas principais
